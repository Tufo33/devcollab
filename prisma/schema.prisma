generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  workspaces      Workspace[] @relation("WorkspaceOwner")
  createdTasks    Task[]      @relation("TaskCreator")
  assignedTasks   Task[]      @relation("TaskAssigned")
  messages        Message[]
  workspaceMembers WorkspaceMember[]
}

model Workspace {
  id        Int      @id @default(autoincrement())
  name      String
  ownerId   Int
  createdAt DateTime @default(now())

  owner     User      @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  tasks     Task[]
  messages  Message[]
  members   WorkspaceMember[]
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  status      String
  userId      Int
  assignedTo  Int
  workspaceId Int
  createdAt   DateTime @default(now())

  user        User      @relation("TaskCreator", fields: [userId], references: [id])
  assigned    User      @relation("TaskAssigned", fields: [assignedTo], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model Message {
  id          Int      @id @default(autoincrement())
  content     String
  userId      Int
  workspaceId Int
  createdAt   DateTime @default(now())

  user        User      @relation(fields: [userId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model WorkspaceMember {
  id          Int       @id @default(autoincrement())
  role        String
  joinedAt    DateTime  @default(now())
  userId      Int
  workspaceId Int
  user        User        @relation(fields: [userId], references: [id])
  workspace   Workspace   @relation(fields: [workspaceId], references: [id])
}